{
  "name": "heliokit",
  "version": "1.0.0",
  "description": "A CLI to add HelioKit UI components to your project",
  "type": "module",
  "bin": {
    "heliokit": "dist/index.js"
  },
  "keywords": [
    "cli",
    "ui",
    "components",
    "tailwind",
    "heliokit"
  ],
  "author": "Mihir Jataniya",
  "license": "MIT",
  "private": false,
  "scripts": {
    "dev": "vite",
    "build": "tsup cli/index.ts --format esm --out-dir dist",
    "lint": "eslint .",
    "preview": "vite preview",
    "release": "npm version patch && npm run build && npm publish --access public"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.8.2",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "framer-motion": "^12.12.2",
    "fs-extra": "^11.3.0",
    "inquirer": "^12.6.1",
    "lucide-react": "^0.511.0",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.6.0",
    "react-syntax-highlighter": "^15.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/vite": "^4.1.7",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.15.19",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.7",
    "tsup": "^8.5.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  }
}
